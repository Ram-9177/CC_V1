+        f'gatepass_student_{instance.student.id}',
+        status_payload,
+    )
+
+    security_payload = {
+        **status_payload,
+        'target': 'security',
+    }
+    async_to_sync(channel_layer.group_send)('gatepass_security', security_payload)
