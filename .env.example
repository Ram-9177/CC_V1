# This file documents the environment variables used by HostelConnect.
# Do NOT commit real secrets. Cloudflare Pages should store these in project settings.

# MongoDB Atlas Driver Connection (Data API deprecated Sept 2025)
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DATABASE=hostel

# Auth
ADMIN_EMAIL=admin@hostelconnect.local
ADMIN_PASSWORD=change-me
JWT_SECRET=replace-with-long-random-hex
# Frontend environment variables for Vite
# Copy this file to .env and adjust values

# REST API base URL
VITE_API_URL=

# WebSocket endpoint (Socket.IO)
# Example: ws://localhost:4000 or wss://api.example.com
VITE_WS_URL=

# Web Push (PWA) VAPID Public Key (Base64URL)
# Generate once and paste here; backend needs both public/private
VITE_VAPID_PUBLIC_KEY=

# ----------------------------
# Backend (serverless API)
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
MONGO_POOL_SIZE=5

# Cloudflare Pages + MongoDB Atlas Data API
MONGODB_DATA_API_URL=
MONGODB_DATA_SOURCE=
MONGODB_DATABASE=
MONGODB_API_KEY=
