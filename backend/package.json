{
  "name": "hostelconnect-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint '{src,test}/**/*.ts' --fix",
    "format": "prettier --write '{src,test}/**/*.{ts,js,json,md}'",
    "test": "jest --passWithNoTests --config=jest.config.ts",
    "test:e2e": "jest --runInBand --config=jest.config.cjs --testPathPatterns=./test/e2e",
    "test:watch": "jest --watch --config=jest.config.ts",
    "typeorm:cli": "node -r ts-node/register ./node_modules/typeorm/cli.js",
    "migrate:run": "npm run typeorm:cli -- migration:run -d ./src/data-source.ts",
    "migrate:generate": "npm run typeorm:cli -- migration:generate -d ./src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^3.0.0",
  "@nestjs/swagger": "^7.0.0",
  "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csv-parse": "^6.1.0",
    "firebase-admin": "^11.9.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.10.0",
    "qrcode": "^1.5.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^4.6.3",
    "typeorm": "^0.3.17",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "@jest/types": "^29.6.3",
    "@nestjs/cli": "^10.0.0",
  "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.5",
  "@types/jest": "^29.5.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.24",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
  "eslint": "^9.11.0",
  "jest": "^29.7.0",
    "prettier": "^2.8.0",
    "socket.io-client": "^4.7.5",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.4",
  "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
