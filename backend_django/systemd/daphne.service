[Unit]
Description=CampusCore Daphne ASGI Service
After=network.target redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/CC_V1/backend_django
Environment=DJANGO_SETTINGS_MODULE=hostelconnect.settings.base
ExecStart=/root/venv/bin/daphne -b 127.0.0.1 -p 8000 core.asgi:application
Restart=always
RestartSec=5
TimeoutStartSec=60
TimeoutStopSec=30
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target

