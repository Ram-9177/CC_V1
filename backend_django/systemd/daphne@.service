[Unit]
Description=CampusCore Daphne ASGI Service (port %i)
After=network.target redis-server.service postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/campuscore/backend_django
Environment=DJANGO_SETTINGS_MODULE=hostelconnect.settings.base
ExecStart=/var/www/campuscore/backend_django/venv/bin/daphne -b 127.0.0.1 -p %i hostelconnect.asgi:application
Restart=always
RestartSec=5
LimitNOFILE=65535
TimeoutStartSec=60
TimeoutStopSec=30
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
