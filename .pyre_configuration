{
  "source_directories": [
    "backend_django"
  ],
  "search_path": [
    ".venv/lib/python3.9/site-packages"
  ],
  "exclude": [
    ".*/__pycache__/.*",
    ".*/migrations/.*",
    "backend_django/htmlcov/.*",
    "backend_django/staticfiles/.*",
    "backend_django/media/.*",
    "src/.*",
    "node_modules/.*",
    "dist/.*"
  ],
  "ignore_all_errors": [
    "backend_django/scripts",
    "backend_django/src_archive"
  ]
}
